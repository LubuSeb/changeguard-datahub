# demo is fully functional and requires no credentials.
DATAHUB_MODE=demo
PORT=8787

# Enable the bounded local reasoning stage. No cloud credential is required.
# When enabled, analysis fails closed if the model is unavailable or ungrounded.
CHANGEGUARD_REASONER=ollama
CHANGEGUARD_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_BASE_URL=http://127.0.0.1:11434

