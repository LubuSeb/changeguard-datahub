{
  "name": "changeguard-datahub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A DataHub-grounded schema change passport agent.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:lambda": "npm run build && node scripts/build-lambda.mjs",
    "start": "node dist-server/server/index.js",
    "test": "vitest run --config vitest.config.ts",
    "test:live": "tsx src/server/integration/live-smoke.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xyflow/react": "^12.11.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serverless-http": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
